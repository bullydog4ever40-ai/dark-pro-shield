  0x90,0xd8,0xab,0x00,0x8c,0xbc,0xd3,0x0a,0xf7,0xe4,0x58,0x05,0xb8,0xb3,0x45,0x06,
  0xd0,0x2c,0x1e,0x8f,0xca,0x3f,0x0f,0x02,0xc1,0xaf,0xbd,0x03,0x01,0x13,0x8a,0x6b,
  0x3a,0x91,0x11,0x41,0x4f,0x67,0xdc,0xea,0x97,0xf2,0xcf,0xce,0xf0,0xb4,0xe6,0x73,
  0x96,0xac,0x74,0x22,0xe7,0xad,0x35,0x85,0xe2,0xf9,0x37,0xe8,0x1c,0x75,0xdf,0x6e,
  0x47,0xf1,0x1a,0x71,0x1d,0x29,0xc5,0x89,0x6f,0xb7,0x62,0x0e,0xaa,0x18,0xbe,0x1b,
  0xfc,0x56,0x3e,0x4b,0xc6,0xd2,0x79,0x20,0x9a,0xdb,0xc0,0xfe,0x78,0xcd,0x5a,0xf4,
  0x1f,0xdd,0xa8,0x33,0x88,0x07,0xc7,0x31,0xb1,0x12,0x10,0x59,0x27,0x80,0xec,0x5f,
  0x60,0x51,0x7f,0xa9,0x19,0xb5,0x4a,0x0d,0x2d,0xe5,0x7a,0x9f,0x93,0xc9,0x9c,0xef,
  0xa0,0xe0,0x3b,0x4d,0xae,0x2a,0xf5,0xb0,0xc8,0xeb,0xbb,0x3c,0x83,0x53,0x99,0x61,
  0x17,0x2b,0x04,0x7e,0xba,0x77,0xd6,0x26,0xe1,0x69,0x14,0x63,0x55,0x21,0x0c,0x7d
};
static uint8_t gm(uint8_t a,uint8_t b){uint8_t p=0;for(int i=0;i<8;++i){if(b&1)p^=a;bool hi=a&0x80;a<<=1;if(hi)a^=0x1b;b>>=1;}return p;}
using Blk=std::array<uint8_t,16>;
using RK=std::array<Blk,15>;
static RK expand(const uint8_t*k){
  const uint8_t RC[10]={0x01,0x02,0x04,0x08,0x10,0x20,0x40,0x80,0x1b,0x36};
  uint32_t w[60];
  for(int i=0;i<8;++i)w[i]=(k[4*i]<<24)|(k[4*i+1]<<16)|(k[4*i+2]<<8)|k[4*i+3];
  for(int i=8;i<60;++i){uint32_t t=w[i-1];if(i%8==0){t=((uint32_t)S[(t>>16)&0xff]<<24)|((uint32_t)S[(t>>8)&0xff]<<16)|((uint32_t)S[t&0xff]<<8)|((uint32_t)S[(t>>24)&0xff]);t^=(uint32_t)RC[i/8-1]<<24;}else if(i%8==4){t=((uint32_t)S[(t>>24)&0xff]<<24)|((uint32_t)S[(t>>16)&0xff]<<16)|((uint32_t)S[(t>>8)&0xff]<<8)|((uint32_t)S[t&0xff]);}w[i]=w[i-8]^t;}
  RK rk;for(int r=0;r<=14;++r)for(int c=0;c<4;++c){uint32_t v=w[r*4+c];rk[r][c*4]=(v>>24)&0xff;rk[r][c*4+1]=(v>>16)&0xff;rk[r][c*4+2]=(v>>8)&0xff;rk[r][c*4+3]=v&0xff;}
  return rk;
}
static void xrk(Blk&s,const Blk&r){for(int i=0;i<16;++i)s[i]^=r[i];}
static Blk enc(Blk b,const RK&rk){
  xrk(b,rk[0]);
  for(int r=1;r<14;++r){
    for(auto&x:b)x=S[x];
    uint8_t t;t=b[1];b[1]=b[5];b[5]=b[9];b[9]=b[13];b[13]=t;
    t=b[2];b[2]=b[10];b[10]=t;t=b[6];b[6]=b[14];b[14]=t;
    t=b[15];b[15]=b[11];b[11]=b[7];b[7]=b[3];b[3]=t;
    for(int c=0;c<4;++c){uint8_t a=b[c*4],bv=b[c*4+1],cc=b[c*4+2],d=b[c*4+3];b[c*4]=gm(2,a)^gm(3,bv)^cc^d;b[c*4+1]=a^gm(2,bv)^gm(3,cc)^d;b[c*4+2]=a^bv^gm(2,cc)^gm(3,d);b[c*4+3]=gm(3,a)^bv^cc^gm(2,d);}
    xrk(b,rk[r]);
  }
  for(auto&x:b)x=S[x];
  uint8_t t;t=b[1];b[1]=b[5];b[5]=b[9];b[9]=b[13];b[13]=t;
  t=b[2];b[2]=b[10];b[10]=t;t=b[6];b[6]=b[14];b[14]=t;
  t=b[15];b[15]=b[11];b[11]=b[7];b[7]=b[3];b[3]=t;
  xrk(b,rk[14]);return b;
}
static Blk dec(Blk b,const RK&rk){
  xrk(b,rk[14]);
  for(int r=13;r>0;--r){
    uint8_t t;t=b[13];b[13]=b[9];b[9]=b[5];b[5]=b[1];b[1]=t;
    t=b[2];b[2]=b[10];b[10]=t;t=b[6];b[6]=b[14];b[14]=t;
    t=b[3];b[3]=b[7];b[7]=b[11];b[11]=b[15];b[15]=t;
    for(auto&x:b)x=Si[x];
    xrk(b,rk[r]);
    for(int c=0;c<4;++c){uint8_t a=b[c*4],bv=b[c*4+1],cc=b[c*4+2],d=b[c*4+3];b[c*4]=gm(0xe,a)^gm(0xb,bv)^gm(0xd,cc)^gm(0x9,d);b[c*4+1]=gm(0x9,a)^gm(0xe,bv)^gm(0xb,cc)^gm(0xd,d);b[c*4+2]=gm(0xd,a)^gm(0x9,bv)^gm(0xe,cc)^gm(0xb,d);b[c*4+3]=gm(0xb,a)^gm(0xd,bv)^gm(0x9,cc)^gm(0xe,d);}
  }
  uint8_t t;t=b[13];b[13]=b[9];b[9]=b[5];b[5]=b[1];b[1]=t;
  t=b[2];b[2]=b[10];b[10]=t;t=b[6];b[6]=b[14];b[14]=t;
  t=b[3];b[3]=b[7];b[7]=b[11];b[11]=b[15];b[15]=t;
  for(auto&x:b)x=Si[x];xrk(b,rk[0]);return b;
}
} // aes

// ── File format + CBC ────────────────────────────────────────────────────────
static const uint8_t MAGIC[8]={'E','N','C','R','Y','P','T','1'};

static aes::Blk mkblk(const uint8_t*p){aes::Blk b;std::copy(p,p+16,b.begin());return b;}
static void xblk(aes::Blk&a,const aes::Blk&b){for(int i=0;i<16;++i)a[i]^=b[i];}

std::vector<uint8_t> do_enc(const std::vector<uint8_t>&plain,const std::string&pass){
  std::random_device rd;
  std::array<uint8_t,16> salt,iv;
  for(auto&b:salt)b=(uint8_t)rd();for(auto&b:iv)b=(uint8_t)rd();
  auto key=pbkdf2(pass,salt.data(),16,100000,32);
  auto rk=aes::expand(key.data());
  // PKCS#7 pad
  size_t pad=16-(plain.size()%16);
  std::vector<uint8_t> msg=plain;for(size_t i=0;i<pad;++i)msg.push_back((uint8_t)pad);
  std::vector<uint8_t> ct(msg.size());
  aes::Blk prev=mkblk(iv.data());
  for(size_t i=0;i<msg.size();i+=16){auto blk=mkblk(msg.data()+i);xblk(blk,prev);prev=aes::enc(blk,rk);std::copy(prev.begin(),prev.end(),ct.begin()+i);}
  std::vector<uint8_t> out;
  out.insert(out.end(),MAGIC,MAGIC+8);out.insert(out.end(),salt.begin(),salt.end());
  out.insert(out.end(),iv.begin(),iv.end());out.insert(out.end(),ct.begin(),ct.end());
  std::fill(key.begin(),key.end(),0);return out;
}

std::vector<uint8_t> do_dec(const std::vector<uint8_t>&blob,const std::string&pass){
  if(blob.size()<8+16+16+16)throw std::runtime_error("File too small");
  if(memcmp(blob.data(),MAGIC,8)!=0)throw std::runtime_error("Not an encrypted file");
  const uint8_t*salt=blob.data()+8,*ivp=salt+16,*ct=ivp+16;size_t clen=blob.size()-40;
  auto key=pbkdf2(pass,salt,16,100000,32);
  auto rk=aes::expand(key.data());
  std::vector<uint8_t> plain(clen);
  aes::Blk prev=mkblk(ivp);
  for(size_t i=0;i<clen;i+=16){auto blk=mkblk(ct+i);auto d=aes::dec(blk,rk);xblk(d,prev);std::copy(d.begin(),d.end(),plain.begin()+i);prev=blk;}
  std::fill(key.begin(),key.end(),0);
  // PKCS#7 unpad
  if(plain.empty()||plain.size()%16)throw std::runtime_error("Bad ciphertext");
  uint8_t pad=plain.back();if(pad==0||pad>16)throw std::runtime_error("Wrong password or corrupted");
  for(size_t i=plain.size()-pad;i<plain.size();++i)if(plain[i]!=pad)throw std::runtime_error("Wrong password or corrupted");
  plain.resize(plain.size()-pad);return plain;
}

static std::vector<uint8_t> rf(const std::string&p){std::ifstream f(p,std::ios::binary);if(!f)throw std::runtime_error("Cannot open: "+p);return{std::istreambuf_iterator<char>(f),{}};}
static void wf(const std::string&p,const std::vector<uint8_t>&d){std::ofstream f(p,std::ios::binary);if(!f)throw std::runtime_error("Cannot create: "+p);f.write((const char*)d.data(),d.size());}

int main(int argc,char*argv[]){
  if(argc!=5){std::cerr<<"Usage: "<<argv[0]<<" enc|dec <input> <output> <password>\n";return 1;}
  std::string mode=argv[1],in=argv[2],out=argv[3],pass=argv[4];
  try{
    auto data=rf(in);
    if(mode=="enc"){auto r=do_enc(data,pass);wf(out,r);std::cout<<"Encrypted: "<<in<<" -> "<<out<<" ("<<r.size()<<" bytes)\n";}
    else if(mode=="dec"){auto r=do_dec(data,pass);wf(out,r);std::cout<<"Decrypted: "<<in<<" -> "<<out<<" ("<<r.size()<<" bytes)\n";}
    else{std::cerr<<"Unknown mode\n";return 1;}
  }catch(const std::exception&e){std::cerr<<"Error: "<<e.what()<<"\n";return 1;}
}
