/**
 * encrypt.cpp — Self-contained AES-256-CBC, no external deps.
 * Build: g++ -std=c++17 -O2 -o encrypt encrypt_v2.cpp
 * Usage: ./encrypt enc <in> <out> <pass>
 *        ./encrypt dec <in> <out> <pass>
 */
#include <iostream>
#include <fstream>
#include <vector>
#include <string>
#include <cstring>
#include <cstdint>
#include <array>
#include <stdexcept>
#include <random>
#include <algorithm>

// ── SHA-256 ──────────────────────────────────────────────────────────────────
namespace sha256_impl {
static constexpr uint32_t K[64]={
  0x428a2f98,0x71374491,0xb5c0fbcf,0xe9b5dba5,0x3956c25b,0x59f111f1,0x923f82a4,0xab1c5ed5,
  0xd807aa98,0x12835b01,0x243185be,0x550c7dc3,0x72be5d74,0x80deb1fe,0x9bdc06a7,0xc19bf174,
  0xe49b69c1,0xefbe4786,0x0fc19dc6,0x240ca1cc,0x2de92c6f,0x4a7484aa,0x5cb0a9dc,0x76f988da,
  0x983e5152,0xa831c66d,0xb00327c8,0xbf597fc7,0xc6e00bf3,0xd5a79147,0x06ca6351,0x14292967,
  0x27b70a85,0x2e1b2138,0x4d2c6dfc,0x53380d13,0x650a7354,0x766a0abb,0x81c2c92e,0x92722c85,
  0xa2bfe8a1,0xa81a664b,0xc24b8b70,0xc76c51a3,0xd192e819,0xd6990624,0xf40e3585,0x106aa070,
  0x19a4c116,0x1e376c08,0x2748774c,0x34b0bcb5,0x391c0cb3,0x4ed8aa4a,0x5b9cca4f,0x682e6ff3,
  0x748f82ee,0x78a5636f,0x84c87814,0x8cc70208,0x90befffa,0xa4506ceb,0xbef9a3f7,0xc67178f2
};
static uint32_t rotr(uint32_t x,int n){return(x>>n)|(x<<(32-n));}
static std::array<uint8_t,32> hash(const uint8_t*data,size_t len){
  uint32_t h[8]={0x6a09e667,0xbb67ae85,0x3c6ef372,0xa54ff53a,0x510e527f,0x9b05688c,0x1f83d9ab,0x5be0cd19};
  std::vector<uint8_t> msg(data,data+len);
  msg.push_back(0x80);
  while(msg.size()%64!=56)msg.push_back(0);
  uint64_t bl=(uint64_t)len*8;
  for(int i=7;i>=0;--i)msg.push_back((uint8_t)(bl>>(i*8)));
  for(size_t off=0;off<msg.size();off+=64){
    uint32_t w[64];
    for(int i=0;i<16;++i)w[i]=((uint32_t)msg[off+i*4]<<24)|((uint32_t)msg[off+i*4+1]<<16)|((uint32_t)msg[off+i*4+2]<<8)|(uint32_t)msg[off+i*4+3];
    for(int i=16;i<64;++i){uint32_t s0=rotr(w[i-15],7)^rotr(w[i-15],18)^(w[i-15]>>3);uint32_t s1=rotr(w[i-2],17)^rotr(w[i-2],19)^(w[i-2]>>10);w[i]=w[i-16]+s0+w[i-7]+s1;}
    uint32_t a=h[0],b=h[1],c=h[2],d=h[3],e=h[4],f=h[5],g=h[6],hh=h[7];
    for(int i=0;i<64;++i){uint32_t S1=rotr(e,6)^rotr(e,11)^rotr(e,25);uint32_t ch=(e&f)^(~e&g);uint32_t t1=hh+S1+ch+K[i]+w[i];uint32_t S0=rotr(a,2)^rotr(a,13)^rotr(a,22);uint32_t maj=(a&b)^(a&c)^(b&c);uint32_t t2=S0+maj;hh=g;g=f;f=e;e=d+t1;d=c;c=b;b=a;a=t1+t2;}
    h[0]+=a;h[1]+=b;h[2]+=c;h[3]+=d;h[4]+=e;h[5]+=f;h[6]+=g;h[7]+=hh;
  }
  std::array<uint8_t,32> out;
  for(int i=0;i<8;++i)for(int j=0;j<4;++j)out[i*4+j]=(h[i]>>(24-j*8))&0xff;
  return out;
}
static std::array<uint8_t,32> hmac(const uint8_t*key,size_t klen,const uint8_t*msg,size_t mlen){
  uint8_t k[64]={};
  if(klen>64){auto h2=hash(key,klen);std::copy(h2.begin(),h2.end(),k);}else std::copy(key,key+klen,k);
  uint8_t ip[64],op[64];for(int i=0;i<64;++i){ip[i]=k[i]^0x36;op[i]=k[i]^0x5c;}
  std::vector<uint8_t> inner(64+mlen);std::copy(ip,ip+64,inner.begin());std::copy(msg,msg+mlen,inner.begin()+64);
  auto ih=hash(inner.data(),inner.size());
  std::vector<uint8_t> outer(64+32);std::copy(op,op+64,outer.begin());std::copy(ih.begin(),ih.end(),outer.begin()+64);
  return hash(outer.data(),outer.size());
}
} // sha256_impl

static std::vector<uint8_t> pbkdf2(const std::string&pass,const uint8_t*salt,size_t slen,int iter,size_t dklen){
  std::vector<uint8_t> dk;const uint8_t*pk=(const uint8_t*)pass.data();
  for(uint32_t blk=1;dk.size()<dklen;++blk){
    std::vector<uint8_t> s(slen+4);std::copy(salt,salt+slen,s.begin());
    s[slen]=(blk>>24)&0xff;s[slen+1]=(blk>>16)&0xff;s[slen+2]=(blk>>8)&0xff;s[slen+3]=blk&0xff;
    auto u=sha256_impl::hmac(pk,pass.size(),s.data(),s.size());
    std::array<uint8_t,32> t=u;
    for(int i=1;i<iter;++i){u=sha256_impl::hmac(pk,pass.size(),u.data(),32);for(int j=0;j<32;++j)t[j]^=u[j];}
    for(auto b:t)dk.push_back(b);
  }
  dk.resize(dklen);return dk;
}

// ── AES-256 ──────────────────────────────────────────────────────────────────
namespace aes {
